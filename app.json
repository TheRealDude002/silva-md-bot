{
  "name": "silva-md",
  "description": "Silva MD — A feature-rich multi-device WhatsApp bot with 1200+ commands, AI agent, auto-status, anti-delete, sudo system, and 19 smart features. Built with Node.js and Baileys.",
  "keywords": ["silva-md", "whatsapp", "baileys", "bot", "multi-device", "ai", "chatbot", "whatsapp-bot", "nodejs"],
  "logo": "https://files.catbox.moe/5uli5p.jpeg",
  "repository": "https://github.com/SilvaTechB/silva-md-bot",
  "website": "https://silvatech.co.ke",
  "success_url": "/",
  "stack": "heroku-26",
  "env": {
    "SESSION_ID": {
      "description": "Session ID",
      "required": true,
      "value": "Silva~"
    },
    "OWNER_NUMBER": {
      "description": "2347025667023",
      "required": true,
      "value": ""
    },
    "PREFIX": {
      "description": "Command prefix. Single: '.' | Multiple: '.,!,/,?' | Any symbol: 'any' | No prefix: 'none'.",
      "required": false,
      "value": "."
    },
    "MODE": {
      "description": "Bot mode: public (everyone), private (owner only), group (groups only), inbox (DM only), both (public).",
      "required": false,
      "value": "public"
    },
    "BOT_NAME": {
      "description": "Bot display name shown in menus and greetings.",
      "required": false,
      "value": "✦ Clayyyyyy ✦"
    },
    "OWNER_NAME": {
      "description": "Bot owner's display name.",
      "required": false,
      "value": "Clayyyyyyy"
    },
    "THEME": {
      "description": "Bot theme/voice. Options: silva, adam, ayanokoji, edith, friday, genos, gideon, gojo, goku, luffy, naruto, nezuko, parker, secktor, suhail, zerotwo, itachi, batman, thanos.",
      "required": false,
      "value": "thanos"
    },
    "ALIVE_IMG": {
      "description": "Image URL shown with the alive/menu command.",
      "required": false,
      "value": "https://static.wikia.nocookie.net/all-worlds-alliance/images/2/21/EscanorRender.png"
    },
    "GEMINI_API_KEY": {
      "description": "Google Gemini API key for advanced AI responses. Get it from ai.google.dev.",
      "required": false,
      "value": ""
    },
    "ANTIDELETE_GROUP": {
      "description": "Recover deleted messages in groups (true/false).",
      "required": false,
      "value": "true"
    },
    "ANTIDELETE_PRIVATE": {
      "description": "Recover deleted messages in private chats (true/false).",
      "required": false,
      "value": "true"
    },
    "AUTO_STATUS_SEEN": {
      "description": "Auto-view all WhatsApp status updates (true/false).",
      "required": false,
      "value": "true"
    },
    "AUTO_STATUS_REACT": {
      "description": "Auto-react to status updates with emoji (true/false).",
      "required": false,
      "value": "true"
    },
    "ALWAYS_ONLINE": {
      "description": "Keep bot always shown as online (true/false).",
      "required": false,
      "value": "true"
    },
    "ANTIVV": {
      "description": "Auto-recover view-once messages (true/false).",
      "required": false,
      "value": "true"
    },
    "ANTILINK": {
      "description": "Auto-remove links in groups (true/false).",
      "required": false,
      "value": "false"
    },
    "ANTICALL": {
      "description": "Auto-reject all incoming WhatsApp calls and notify owner (true/false).",
      "required": false,
      "value": "true"
    },
    "TIMEZONE": {
      "description": "Timezone for date/time features (e.g. Africa/Nairobi, America/New_York).",
      "required": false,
      "value": "Africa/Nairobi"
    },
    "AUTO_JOIN_GROUPS": {
      "description": "Comma-separated group invite codes to auto-join on startup. Leave blank to disable.",
      "required": false,
      "value": ""
    },
    "PORT": {
      "description": "HTTP server port for the web dashboard.",
      "required": false,
      "value": "25680"
    }
  },
  "formation": {
    "web": {
      "quantity": 1,
      "size": "basic"
    }
  },
  "buildpacks": [
    {
      "url": "https://github.com/heroku/heroku-buildpack-nodejs.git"
    }
  ]
}
